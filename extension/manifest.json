{
  "manifest_version": 3,
  "name": "Tenmen Patch Review",
  "version": "1.0.0",
  "description": "Review and apply feature document patches from the Tenmen side panel",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://script.google.com/*"
  ],
  "action": {
    "default_title": "Tenmen Patch Review"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/d/*/edit*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
