{
  "mcpServers": {},
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git apply:*)",
      "Bash(git worktree:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(node:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npx tsc:*)",
      "Bash(npx jest:*)",
      "Bash(yarn test:*)",
      "Bash(yarn build)",
      "Bash(yarn install:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
